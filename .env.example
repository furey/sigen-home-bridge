# These values seed the first boot only. After you save in the setup wizard or
# settings UI, /data/settings.json holds the live configuration and takes
# precedence over everything here (TZ, CLOUDFLARE_TUNNEL_TOKEN, and DATA_DIR
# are the exceptions; they're read from the environment at process start).

# Modbus TCP gateway.
# SIGEN_IP is your gateway's address on the LAN (see the README for how to find
# it). Leave it blank to set it in the setup wizard on first run instead.
SIGEN_IP=
SIGEN_PORT=502
SIGEN_UNIT_ID=247

# Poll cadence (milliseconds).
# POLL_INTERVAL_MS is the fallback used whenever no schedule window matches.
# POLL_SCHEDULE is an optional comma-separated list of HH:MM-HH:MM@INTERVAL
# windows (local time; a window may wrap past midnight). It seeds the in-app
# settings GUI; once you save there, /data/settings.json takes precedence.
POLL_INTERVAL_MS=5000
RECONNECT_DELAY_MS=10000
# POLL_SCHEDULE=08:00-12:00@5000,17:00-21:00@10000
TZ=UTC

# Web server + dashboard
SERVER_PORT=5163

# Trend history retention (days, 1-90). Seeds the default; editable under
# Settings > History, which also exports the readings as CSV or JSON. Readings
# persist to /data/history.db (SQLite), written one row per poll.
# HISTORY_RETENTION_DAYS=7

# Outdoor temperature (shown in the dashboard header).
# Fetched from Open-Meteo (free, no key). Set WEATHER_ENABLED=false to turn it
# off entirely. By default the location is resolved once at startup from the
# server's public IP (a coarse, city-level lookup via ip-api.com); set LATITUDE
# and LONGITUDE to skip that lookup and pin exact coordinates.
# WEATHER_ENABLED=true
# LATITUDE=
# LONGITUDE=
# WEATHER_UNITS=celsius
# WEATHER_REFRESH_MS=600000

# HomeKit
HOMEKIT_NAME=Sigenergy
HOMEKIT_PIN=516-35-163
HOMEKIT_PORT=51826
# Restrict the HomeKit advertisement to one interface or IP. On a Docker
# host-network setup with extra bridge networks (typical on a NAS), leaving this
# unset makes the bridge advertise on every interface, including unreachable
# 172.x Docker addresses that can slow the Home app's connection. Set it to your
# LAN interface (e.g. eth0) or its IP. This seeds the default; you can also set it
# under Settings > Apple Home (applies on restart).
# HOMEKIT_BIND=eth0

# Google Smart Home
# Static bearer returned by the stub OAuth endpoints (personal use only).
GOOGLE_AUTH_TOKEN=sigen-home-bridge-token
# Cloudflare Tunnel token (exposes SERVER_PORT over HTTPS for Google fulfillment).
CLOUDFLARE_TUNNEL_TOKEN=

# Persistence directory for HAP pairing and saved poll settings.
# Docker sets this to /data; for local dev it defaults to ./data.
# DATA_DIR=./data
